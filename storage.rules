rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Crops — public read, authenticated write
    match /crops/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Models — public read (M4 workers download), server-only write
    match /models/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Exports — public read, authenticated write
    match /exports/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
