# ──────────────────────────────────────────────────────────
# CurbScout Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────────────────

# ── GCP / Firebase ──
GOOGLE_CLOUD_PROJECT=curbscout-project
GCP_BUCKET=curbscout-artifacts
GCP_LOCATION=us-central1

# ── Cloud Tasks Queue Names ──
M4_QUEUE_NAME=m4-inference
VAST_QUEUE_NAME=vast-training

# ── API Keys ──
# Shared key between M4 workers and Hub for sync/heartbeat auth
WORKER_API_KEY=dev-worker-key

# Vast.ai webhook auth key
VAST_API_KEY=dev-vast-key

# ── Mapbox (Analytics Dashboard) ──
# Get a token at https://account.mapbox.com/
PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ── Active Learning ──
# Minimum corrections before auto-training triggers
AUTO_TRAIN_THRESHOLD=100

# ── Cloud Run URL (set after first deploy) ──
GCP_HUB_URL=http://localhost:5173

# ── M4 Worker Identity ──
# Auto-detected from hostname if not set
# WORKER_ID=m4-macmini-001

# ── Firebase Admin SDK ──
# Path to service account JSON (for local dev only; Cloud Run uses attached SA)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
